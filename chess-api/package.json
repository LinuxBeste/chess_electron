{
  "name": "chess-api",
  "version": "1.0.0",
  "type": "module",
  "description": "Multiplayer chess REST API with WebSocket support",
  "scripts": {
    "build": "cd admin-frontend && pnpm run build && cd .. && tsc",
    "start": "node dist/index.js",
    "start:dev": "bash start.sh --native",
    "start:docker": "bash start.sh",
    "dev": "tsx src/index.ts",
    "dev:web": "PORT=25565 tsx src/index.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --runInBand",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --runInBand --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "pg": "^8.13.0",
    "stockfish": "^18.0.7",
    "uuid": "^9.0.0",
    "ws": "^8.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^29.5.11",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.2"
  }
}
