{
  "name": "chess-api",
  "version": "1.0.0",
  "description": "Multiplayer chess REST API with WebSocket support",
  "scripts": {
    "build": "cd admin-frontend && pnpm run build && cd .. && tsc",
    "start": "node dist/index.js",
    "start:dev": "bash start.sh --native",
    "start:docker": "bash start.sh",
    "dev": "ts-node src/index.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "helmet": "^8.0.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^29.5.11",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
