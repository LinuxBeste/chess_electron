#### Server ####
PORT=25565
HOST=0.0.0.0
CORS_ORIGIN=*
CORS_CREDENTIALS=true
MAX_BODY_SIZE=10kb
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000
NODE_ENV=development

#### Security ####
# ENABLE_HELMET=true                        # HTTP security headers
# HSTS_MAX_AGE=31536000                     # 1 year (seconds)
# HSTS_INCLUDE_SUBDOMAINS=true
# HSTS_PRELOAD=false
# CSP_SCRIPT_SRC="'self','unsafe-inline'"  # CSP script-src (comma-sep)
# CSP_STYLE_SRC="'self','unsafe-inline'"   # CSP style-src (comma-sep)

#### Logging ####
LOG_LEVEL=info
# LOG_RETENTION_DAYS=30
# ENABLE_MORGAN=true                        # HTTP request logging
# MORGAN_FORMAT=combined                    # combined | short | dev | tiny

#### PostgreSQL ####
DATABASE_URL=postgresql://chess:chess@localhost:5432/chess
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=5000
# DB_RETRY_DELAY_MS=5000                   # Delay between DB init retries
# DB_RETRY_MAX_ATTEMPTS=5                  # Set 0 to exit immediately
# DB_BACKUP_INTERVAL_MS=21600000           # 6 hours (0 disables)
# DB_PATH=data/chess.db                    # Display path in admin config

#### Admin dashboard ####
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=<set-a-strong-password>    # REQUIRED in production
# ADMIN_TOKEN_TTL=86400000
# ADMIN_LOGIN_MAX_ATTEMPTS=5
# ADMIN_LOGIN_LOCKOUT_MINUTES=15

#### Player sessions ####
# PLAYER_TOKEN_TTL=86400000
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

#### Games ####
# MAX_GAMES_PER_PLAYER=20
# WAITING_TTL_MS=600000                    # 10 minutes
# WAITING_TTL_MINUTES=10                   # Admin config display (same as above)
# COMPLETED_GAME_TTL_MS=300000             # 5 minutes

#### Chat ####
# CHAT_MAX_LENGTH=500
# CHAT_HISTORY_MAX=50
# GROUP_NAME_MAX_LENGTH=50
# GROUP_HISTORY_LIMIT=200

#### Rate limiting (IP-based sliding window) ####
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# IP_RATE_LIMIT_WINDOW_MS=60000
# IP_RATE_LIMIT_MAX=20
# REG_RATE_LIMIT_WINDOW_MS=3600000         # 1 hour
# REG_RATE_LIMIT_MAX=5                     # accounts per hour per IP
# HEALTH_RATE_LIMIT_MAX=60                 # /health requests per window

#### WebSocket ####
# WS_HEARTBEAT_INTERVAL=30000
# WS_PONG_TIMEOUT=10000
# WS_RATE_LIMIT_PER_SEC=10
# WS_MAX_CONNECTIONS_PER_IP=5
# WS_AUTH_MAX_ATTEMPTS=10                  # Failed auth before IP block
# WS_AUTH_BLOCK_DURATION_MS=30000          # IP block duration

#### Game persistence (file fallback, used when Redis is disabled) ####
# ACTIVE_GAMES_FILE=data/active_games.json    # Where active games are saved
# FILE_SAVE_INTERVAL_MS=30000                 # How often to persist (ms)
# DISABLE_FILE_PERSISTENCE=true               # Set to true to disable file fallback

#### Redis ####
# Set REDIS_URL to enable Redis-backed state persistence and
# cross-instance WebSocket messaging.  When unset the server uses
# pure in-memory state (existing behaviour).
# Examples:
#   Docker Compose: redis://redis:6379
#   Local dev:      redis://localhost:6379
# REDIS_URL=
# REDIS_GAME_TTL=3600                        # seconds
# REDIS_CHAT_TTL=3600                        # seconds

#### Engine ####
# MAX_CONCURRENT_ENGINES=4
# ENGINE_POLL_INTERVAL_MS=100
# ENGINE_DEFAULT_MOVETIME_MS=500
# ENGINE_TIMEOUT_BUFFER_MS=10000

#### Elo ####
# ELO_K_FACTOR=32

#### Analysis ####
# ANALYSIS_MOVE_TIME_MS=1000
# ANALYSIS_PLAYED_MOVE_TIME_MS=500

#### Avatar upload ####
# AVATAR_MAX_SIZE_BYTES=2097152             # 2 MB

#### Leaderboard cache ####
# LEADERBOARD_CACHE_TTL=10000               # milliseconds

#### Cleanup intervals ####
# CLEANUP_INTERVAL_MS=60000                 # bucket & stale-game sweep
# LOG_CLEANUP_INTERVAL_MS=86400000          # 24 hours
# TOKEN_CLEANUP_INTERVAL_MS=3600000         # 1 hour

#### Database backup ####
# DB_BACKUP_INTERVAL_MS=21600000            # 6 hours

#### CLI admin tool ####
# DISABLE_CLI=true                           # Set to prevent chess-admin CLI from loading
