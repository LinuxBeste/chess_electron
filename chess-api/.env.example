#### Server ####
PORT=25565
HTTPS_PORT=25566
HOST=0.0.0.0
NODE_ENV=development
API_PREFIX=/v1

#### CORS ####
CORS_ORIGIN=*
CORS_CREDENTIALS=true

#### Security ####
ENABLE_HELMET=true
ENABLE_HTTPS=false
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false
CSP_SCRIPT_SRC='self','unsafe-inline'
CSP_STYLE_SRC='self','unsafe-inline'
MAX_BODY_SIZE=10kb
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000

#### Admin ####
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=           # auto-generated if not set
ADMIN_TOKEN_TTL=86400000
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15

#### Database (PostgreSQL) ####
DATABASE_URL=postgresql://chess:chess@localhost:5432/chess
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_RETRY_DELAY_MS=5000
DB_RETRY_MAX_ATTEMPTS=5
DB_BACKUP_INTERVAL_MS=21600000
DB_PATH=data/chess.db

#### Redis (optional — omit to run without Redis) ####
# REDIS_URL=redis://localhost:6379
REDIS_GAME_TTL=3600
REDIS_CHAT_TTL=3600

#### File Persistence (fallback when Redis is disabled) ####
ACTIVE_GAMES_FILE=data/active_games.json
FILE_SAVE_INTERVAL_MS=30000
FILE_SAVE_GAME_WARN_THRESHOLD=5000
DISABLE_FILE_PERSISTENCE=false

#### Rate Limiting ####
# Raise for load testing (defaults in docker-compose.yml are set higher)
# IP_RATE_LIMIT_MAX=100000
# REG_RATE_LIMIT_MAX=100000
# RATE_LIMIT_MAX_REQUESTS=100000
# WS_MAX_CONNECTIONS_PER_IP=1000

#### Players ####
PLAYER_TOKEN_TTL=86400000
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
MAX_GAMES_PER_PLAYER=20
TOTAL_MAX_GAMES=10000
AVATAR_MAX_SIZE_BYTES=2097152

#### Games ####
WAITING_TTL_MS=600000
WAITING_TTL_MINUTES=10
COMPLETED_GAME_TTL_MS=300000
GAME_EVENT_BUFFER_TTL_MS=60000
GAME_EVENT_BUFFER_MAX=50
GAME_LIST_CACHE_TTL_MS=500

#### Chat ####
CHAT_MAX_LENGTH=500
CHAT_HISTORY_MAX=50
GROUP_NAME_MAX_LENGTH=50
GROUP_HISTORY_LIMIT=200

#### Rate Limiting ####
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
IP_RATE_LIMIT_WINDOW_MS=60000
IP_RATE_LIMIT_MAX=20
REG_RATE_LIMIT_WINDOW_MS=3600000
REG_RATE_LIMIT_MAX=5
HEALTH_RATE_LIMIT_MAX=60

#### WebSocket ####
WS_HEARTBEAT_INTERVAL=30000
WS_PONG_TIMEOUT=10000
WS_RATE_LIMIT_PER_SEC=10
WS_MAX_CONNECTIONS_PER_IP=5
WS_AUTH_MAX_ATTEMPTS=10
WS_AUTH_BLOCK_DURATION_MS=30000

#### Engine (Stockfish) ####
MAX_CONCURRENT_ENGINES=4
ENGINE_POLL_INTERVAL_MS=100
ENGINE_DEFAULT_MOVETIME_MS=500
ENGINE_TIMEOUT_BUFFER_MS=10000
ANALYSIS_MOVE_TIME_MS=1000
ANALYSIS_PLAYED_MOVE_TIME_MS=500

#### Elo ####
ELO_K_FACTOR=32

#### Leaderboard ####
LEADERBOARD_CACHE_TTL=10000

#### Logging ####
LOG_LEVEL=info
LOG_RETENTION_DAYS=30
LOG_FORMAT=text            # text or json
ENABLE_MORGAN=true
MORGAN_FORMAT=combined

#### Monitoring (Sentry, Prometheus, CAPTCHA) ####
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
DISABLE_METRICS=false
# CAPTCHA_SECRET_KEY=

#### Cleanup ####
CLEANUP_INTERVAL_MS=60000
LOG_CLEANUP_INTERVAL_MS=86400000
TOKEN_CLEANUP_INTERVAL_MS=3600000
EVENT_BUFFER_CLEANUP_INTERVAL_MS=30000

#### CLI ####
DISABLE_CLI=false
