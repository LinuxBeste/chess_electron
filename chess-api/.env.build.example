# ── Build-time environment for chess-api ────────────────────────────
# Copy this file to .env.build and fill in real values.
# .env.build is gitignored; it is sourced by the release workflow.

# Docker image configuration
IMAGE_NAME=ghcr.io/your-org/chess-api
IMAGE_TAG=latest

# Default runtime environment variables baked into docker-compose
PORT=25566
NODE_ENV=production

# Admin credentials — MUST be set for production
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=<set-a-strong-password>

# PostgreSQL connection string — MUST be set for production
# DATABASE_URL=postgresql://user:password@host:5432/chess

# Leaderboard cache TTL (ms)
# LEADERBOARD_CACHE_TTL=10000
