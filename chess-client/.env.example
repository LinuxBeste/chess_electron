# API server URL (used by webpack proxy in dev)
CHESS_SERVER_URL=http://localhost:3000
# WebSocket URL override (defaults to same as CHESS_SERVER_URL)
# CHESS_WS_URL=ws://localhost:3000

# Pre-fill login (empty = no default)
# DEFAULT_USERNAME=
AUTO_CONNECT=true

# Appearance
THEME=default
WINDOW_TITLE=Chess

# Window dimensions
WINDOW_WIDTH=1280
WINDOW_HEIGHT=900
WINDOW_MIN_WIDTH=960
WINDOW_MIN_HEIGHT=700

# Preferences
SOUND_ENABLED=true
SHOW_LEGAL_HINTS=true
DISABLE_HARDWARE_ACCEL=true

# Development
DEVTOOLS=false
