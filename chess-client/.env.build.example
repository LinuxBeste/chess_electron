# ── Build-time environment for chess-client ──────────────────────────
# Copy this file to .env.build and fill in real values.
# .env.build is gitignored; it is sourced by the release workflow.

# Application
APP_VERSION=1.0.0
APP_ID=com.chess.client
APP_NAME=Chess Client

# Server the packaged client connects to (override via env at runtime)
SERVER_URL=http://localhost:25566

# Code signing credentials (macOS)
# CSC_LINK=file:///path/to/cert.p12
# CSC_KEY_PASSWORD=

# Apple notarization (macOS)
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=

# Windows code signing
# WIN_CSC_LINK=file:///path/to/cert.p12
# WIN_CSC_KEY_PASSWORD=
