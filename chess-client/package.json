{
  "name": "chess-client",
  "version": "1.0.0",
  "description": "Premium desktop chess client",
  "author": "Chess App <chess@example.com>",
  "homepage": "https://github.com/your-org/chess-app",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build:web": "NODE_ENV=production webpack --config webpack.renderer.config.js",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "dev:web": "cd ../chess-api && PORT=25565 ts-node src/index.ts & cd ../chess-client && wait-on tcp:localhost:25565 && NODE_ENV=development webpack serve --config webpack.renderer.config.js; kill %1 2>/dev/null",
    "start": "electron .",
    "dev": "pnpm run build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "package": "pnpm run build && electron-builder",
    "package:linux": "pnpm run build && electron-builder --linux",
    "package:mac": "pnpm run build && electron-builder --mac",
    "package:win": "pnpm run build && electron-builder --win",
    "package:all": "pnpm run build && electron-builder --linux --mac --win",
    "build:linux": "pnpm run build && electron-builder --linux",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:win": "pnpm run build && electron-builder --win",
    "build:all": "pnpm run build && electron-builder --linux --mac --win"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "react-router-dom": "^7.16.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
