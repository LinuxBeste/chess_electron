{
  "name": "chess-client",
  "version": "1.0.0",
  "description": "desktop chess client",
  "author": "Chess App <chess@example.com>",
  "homepage": "https://github.com/your-org/chess-app",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "vite build",
    "build:web": "NODE_ENV=production vite build",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "dev:web": "NODE_ENV=development vite --host",
    "dev:stack": "cd ../chess-api && PORT=25565 npx tsx src/index.ts & cd ../chess-client && wait-on tcp:localhost:25565 && pnpm run dev:web; kill %1 2>/dev/null",
    "start": "electron .",
    "dev": "pnpm run build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:general": "jest --testPathPattern='\\.test\\.ts$'",
    "test:ui": "jest --testPathPattern='\\.test\\.tsx$'",
    "package": "pnpm run build && electron-builder",
    "package:linux": "pnpm run build && electron-builder --linux",
    "package:mac": "pnpm run build && electron-builder --mac",
    "package:win": "pnpm run build && electron-builder --win",
    "package:all": "pnpm run build && electron-builder --linux --mac --win",
    "build:linux": "pnpm run build && electron-builder --linux",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:win": "pnpm run build && electron-builder --win",
    "build:all": "pnpm run build && electron-builder --linux --mac --win"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "vite": "^6.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "zod": "^4.4.3"
  }
}
