{
  "name": "chess-client",
  "version": "1.0.0",
  "description": "Premium desktop chess client",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "start": "electron .",
    "dev": "pnpm run build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "package": "pnpm run build && electron-builder"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^29.5.14",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
