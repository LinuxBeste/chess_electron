{
  "appId": "com.chess.client",
  "productName": "Chess Client",
  "directories": {
    "output": "release"
  },
  "files": ["dist/**/*", "assets/**/*"],
  "icon": "assets/icon",
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Game",
    "maintainer": "Chess App <chess@example.com>"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.games"
  },
  "win": {
    "target": ["nsis"],
    "publisherName": "Chess App"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "runAfterFinish": true
  }
}
