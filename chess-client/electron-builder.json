{
  "appId": "com.chess.client",
  "productName": "Chess Client",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    ".env"
  ],
  "icon": "assets/icon.png",
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Game",
    "maintainer": "Chess App <chess@example.com>"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.games"
  },
  "win": {
    "target": ["nsis"]
  }
}
