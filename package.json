{
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter chess-client run dev:web",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "build:website": "pnpm --filter chess-website build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:typecheck": "pnpm lint && pnpm typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx}": "eslint --fix",
    "*.{js,mjs,cjs,ts,tsx,jsx,json,css,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.1",
    "wait-on": "^9.0.10"
  }
}
